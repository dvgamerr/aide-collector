{
  "name": "tokenizer",
  "version": "2.3",
  "module": "src/index.js",
  "scripts": {
    "prepare": "husky",
    "proxy": "cloudflared tunnel run dev",
    "dev": "bun run --watch ./src/index.js | bun x pino-pretty",
    "start": "bun run ./src/index.js",
    "migrate": "bun run ./src/migrate.js",
    "lint:fix": "eslint . --fix",
    "format:fix": "prettier --check . --write"
  },
  "lint-staged": {
    "*": "prettier --check . --write",
    "*.js": "eslint --fix"
  },
  "dependencies": {
    "@elysiajs/swagger": "^1.3.1",
    "dayjs": "^1.11.21",
    "elysia": "^1.4.29",
    "kysely": "^0.29.2",
    "kysely-postgres-js": "^3.0.0",
    "numeral": "^2.0.6",
    "pino": "^10.3.1",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "bun-types": "latest",
    "eslint": "^10.5.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4"
  }
}
