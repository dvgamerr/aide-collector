{
  "name": "tokenizer",
  "version": "2.3",
  "module": "src/index.js",
  "scripts": {
    "prepare": "husky",
    "proxy": "cloudflared tunnel run dev",
    "dev": "bun run --watch ./src/index.js | bun x pino-pretty",
    "start": "bun run ./src/index.js"
  },
  "lint-staged": {
    "*": "prettier --check . --write",
    "*.js": "eslint --fix"
  },
  "dependencies": {
    "@elysiajs/swagger": "^1.3.1",
    "dayjs": "^1.11.13",
    "elysia": "latest",
    "kysely": "^0.27.4",
    "kysely-postgres-js": "^2.0.0",
    "numeral": "^2.0.6",
    "pino": "^9.9.0",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.33.0",
    "bun-types": "latest",
    "eslint": "^9.33.0",
    "eslint-plugin-perfectionist": "^4.15.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.6.2"
  }
}
